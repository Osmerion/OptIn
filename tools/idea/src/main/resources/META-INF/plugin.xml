<idea-plugin>
  <id>com.osmerion.optin</id>
  <name>OptIn</name>
  <vendor url="https://osmerion.com">Osmerion</vendor>

  <depends>com.intellij.java</depends>
  <depends optional="true" config-file="plugin-kotlin.xml">org.jetbrains.kotlin</depends>

  <extensions defaultExtensionNs="com.intellij">
    <globalInspection
      language="JAVA"
      bundle="messages.OptInBundle"
      key="inspection.extra-configuration.name"
      groupPath="Java"
      groupBundle="messages.OptInBundle"
      groupKey="group.opt-in"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="com.osmerion.optin.tools.idea.inspections.ExtraConfigurationInspection" />

    <localInspection
      language="JAVA"
      bundle="messages.OptInBundle"
      key="inspection.java-annotations.name"
      groupPath="Java"
      groupBundle="messages.OptInBundle"
      groupKey="group.opt-in"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="com.osmerion.optin.tools.idea.inspections.JavaAnnotationInspection" />

    <localInspection
      language="JAVA"
      bundle="messages.OptInBundle"
      key="inspection.opt-in.name"
      groupPath="Java"
      groupBundle="messages.OptInBundle"
      groupKey="group.opt-in"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="com.osmerion.optin.tools.idea.inspections.OptInInspection" />

    <localInspection
      language="JAVA"
      bundle="messages.OptInBundle"
      key="inspection.requires-opt-in-usage.name"
      groupPath="Java"
      groupBundle="messages.OptInBundle"
      groupKey="group.opt-in"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="com.osmerion.optin.tools.idea.inspections.RequiresOptInUsageInspection" />

    <localInspection
      language="JAVA"
      bundle="messages.OptInBundle"
      key="inspection.subtyping-requires-opt-in-usage.name"
      groupPath="Java"
      groupBundle="messages.OptInBundle"
      groupKey="group.opt-in"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="com.osmerion.optin.tools.idea.inspections.SubtypingRequiresOptInUsageInspection" />

    <dependencySupport coordinate="com.osmerion.optin:optin" kind="java" displayName="OptIn" />
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <supportsKotlinPluginMode supportsK2="true" />
  </extensions>
</idea-plugin>
